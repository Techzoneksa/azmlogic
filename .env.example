# لا تلتزم بملف .env الحقيقي في Git.
NODE_ENV=production

# رابط التطبيق العام.
NEXT_PUBLIC_APP_URL="https://azmapp.promksa.com"

# demo = بيانات تجريبية، database = إظهار مؤشر قاعدة البيانات في الواجهة بعد ضبط DATABASE_URL.
NEXT_PUBLIC_DATA_MODE=demo

# مطلوب لتفعيل وضع قاعدة البيانات الإنتاجي.
# عند غياب هذا المتغير يعمل التطبيق في وضع البيانات التجريبي.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# يمكن أن يطابق DATABASE_URL ما لم تكن تستخدم connection pooling.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# سر جلسات المنصة. استخدم قيمة طويلة وعشوائية في الإنتاج.
JWT_SECRET="replace-with-secure-secret"

# بيان غير مفعل في هذه المرحلة. لا تضع بيانات اعتماد حقيقية حتى مرحلة التكامل الرسمي.
BAYAN_SERVICE_URL=
BAYAN_CLIENT_ID=
BAYAN_CLIENT_SECRET=
